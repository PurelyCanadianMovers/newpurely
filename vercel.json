{
  "buildCommand": "corepack pnpm build",
  "outputDirectory": "dist/public",
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/login/",
      "permanent": true
    },
    {
      "source": "/distance",
      "destination": "/long-distance/",
      "permanent": true
    },
    {
      "source": "/distance/",
      "destination": "/long-distance/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
